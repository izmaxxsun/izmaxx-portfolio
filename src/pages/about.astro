---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="About — Isra Sunhachawi" description="Engineering leader with 20 years of experience in systems engineering, DevOps, and applied AI.">
  <section class="max-w-4xl mx-auto px-6 py-20">

    <div class="mb-12 animate-fade-in-up">
      <span class="font-mono text-sm" style="color:#D4A017;">$ cat about.md</span>
      <h1 class="text-4xl font-bold mt-3 mb-2" style="color:#E8EDF5;">About Me</h1>
      <div class="h-1 w-16 rounded" style="background: linear-gradient(135deg, #D4A017, #F0C040);"></div>
    </div>

    <div class="grid md:grid-cols-3 gap-12">

      <div class="md:col-span-2 space-y-6 animate-fade-in-up animate-delay-100">
        <p style="color:#7A8BA8; line-height:1.9;">
          I'm a <span style="color:#E8EDF5;">strategic and hands-on engineering leader</span> with 20 years of experience spanning systems engineering, software engineering, DevOps, and pre-sales. I'm recognized for thought leadership in <span style="color:#D4A017;">AI-enabled developer experience</span> and modern DevSecOps — with a proven ability to formulate, prototype, and scale big ideas.
        </p>
        <p style="color:#7A8BA8; line-height:1.9;">
          At Lockheed Martin I lead cross-functional DevSecOps teams and have delivered real outcomes: an <span style="color:#E8EDF5;">MCP Server for automated config generation</span> that cut time-to-deployment by 70%, and an agentic AI workflow that eliminated a two-week sprint from every product planning cycle. I also delivered a disconnected-environment deployment of the Navy MRO system aboard DDG-57 Mitscher.
        </p>
        <p style="color:#7A8BA8; line-height:1.9;">
          I care deeply about <span style="color:#10B981;">data sovereignty</span> — which is why I'm increasingly focused on private, air-gapped AI infrastructure. The engineers who understand both the attack surface of AI systems and how to build with them have a rare and valuable perspective.
        </p>

        <div class="glass-card p-6 mt-8">
          <h2 class="font-bold mb-4" style="color:#E8EDF5;">My Philosophy</h2>
          <ul class="space-y-3">
            {[
              ['Security is code.', 'Policies, guardrails, and controls belong in version control — not wikis.'],
              ['Private AI is not optional in enterprise.', 'Data sovereignty matters. Every LLM call to a third party is a trust decision.'],
              ['Codify what people know.', 'The most dangerous knowledge in any org lives only in someone\'s head.'],
              ['The "why" outlasts the "what".', 'Document your decisions. Future you — and your team — will thank you.'],
            ].map(([title, body]) => (
              <li class="flex gap-3">
                <span style="color:#D4A017; flex-shrink:0; margin-top:2px;">▸</span>
                <span style="color:#7A8BA8;"><span style="color:#E8EDF5;">{title}</span> {body}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="space-y-6 animate-fade-in-up animate-delay-200">
        <div class="glass-card p-5">
          <h3 class="font-mono text-xs mb-4" style="color:#D4A017;">CURRENTLY</h3>
          <ul class="space-y-2 text-sm" style="color:#7A8BA8;">
            <li>DevSecOps tech lead @ Lockheed Martin 1LMX</li>
            <li>Building MCP Servers & agentic AI workflows</li>
            <li>Air-gapped LLM infrastructure on Kubernetes</li>
          </ul>
        </div>

        <div class="glass-card p-5">
          <h3 class="font-mono text-xs mb-4" style="color:#10B981;">FOCUS AREAS</h3>
          <ul class="space-y-2 text-sm" style="color:#7A8BA8;">
            <li>AI-Enabled Developer Experience</li>
            <li>Agentic Workflow Engineering</li>
            <li>Private LLM Infrastructure</li>
            <li>DevSecOps Platform Engineering</li>
            <li>Enterprise AI Guardrails</li>
          </ul>
        </div>

        <a
          href={`${base}resume.pdf`}
          class="flex items-center justify-center gap-2 w-full py-3 rounded-lg text-sm font-semibold transition-all"
          style="background:rgba(212,160,23,0.1); border:1px solid rgba(212,160,23,0.3); color:#D4A017;"
          onmouseover="this.style.background='rgba(212,160,23,0.2)'"
          onmouseout="this.style.background='rgba(212,160,23,0.1)'"
        >
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Download Resume
        </a>
      </div>

    </div>

    <!-- Experience Timeline -->
    <div class="mt-20 animate-fade-in-up">
      <div class="mb-8">
        <span class="font-mono text-sm" style="color:#D4A017;">$ cat experience.log</span>
        <h2 class="text-2xl font-bold mt-3 mb-2" style="color:#E8EDF5;">Experience</h2>
        <div class="h-1 w-16 rounded" style="background: linear-gradient(135deg, #D4A017, #F0C040);"></div>
      </div>

      <div class="space-y-6">

        <div class="glass-card p-6 border-l-2" style="border-left-color:#D4A017;">
          <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
            <div>
              <h3 class="font-bold text-lg" style="color:#E8EDF5;">Systems Engineer Sr. Staff / DevOps</h3>
              <p class="text-sm font-medium" style="color:#D4A017;">Lockheed Martin · Orlando, FL</p>
            </div>
            <span class="font-mono text-xs px-2 py-1 rounded" style="background:rgba(212,160,23,0.1); color:#D4A017;">May 2023 – Present</span>
          </div>
          <ul class="space-y-2 text-sm" style="color:#7A8BA8;">
            <li class="flex gap-2"><span style="color:#D4A017;">▸</span>Lead cross-functional systems engineering for the 1LMX digital transformation DevSecOps team, developing capabilities to improve developer experience</li>
            <li class="flex gap-2"><span style="color:#D4A017;">▸</span>Engineered an MCP Server for automated configuration file generation, integrating LLM-driven tool-use workflows that <span style="color:#E8EDF5;">reduced time-to-deployment by 70%</span></li>
            <li class="flex gap-2"><span style="color:#D4A017;">▸</span>Eliminated a two-week sprint from planning by developing an agentic AI workflow that synthesizes system design artifacts and structures requirements from engineering inputs</li>
            <li class="flex gap-2"><span style="color:#D4A017;">▸</span>Technical lead for a 15-engineer team delivering CI/CD automation across 50+ environments on multi-cluster Kubernetes infrastructure</li>
            <li class="flex gap-2"><span style="color:#D4A017;">▸</span>Delivered disconnected-environment deployment of the Navy MRO system aboard DDG-57 Mitscher</li>
          </ul>
        </div>

        <div class="glass-card p-6 border-l-2" style="border-left-color:#10B981;">
          <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
            <div>
              <h3 class="font-bold text-lg" style="color:#E8EDF5;">Senior Solutions Architect, Public Sector</h3>
              <p class="text-sm font-medium" style="color:#10B981;">Elastic (ELK Stack) · Arlington, VA</p>
            </div>
            <span class="font-mono text-xs px-2 py-1 rounded" style="background:rgba(0,145,110,0.1); color:#10B981;">Feb 2022 – May 2023</span>
          </div>
          <ul class="space-y-2 text-sm" style="color:#7A8BA8;">
            <li class="flex gap-2"><span style="color:#10B981;">▸</span>Developed solution architectures and sizing for observability (APM, metrics, logs), SIEM/endpoint security, and search for agencies including NSF, NIH, FDA, and NASA</li>
            <li class="flex gap-2"><span style="color:#10B981;">▸</span>Displaced incumbent observability solution to land the <span style="color:#E8EDF5;">United Nations</span> as a strategic account — infrastructure monitoring and APM for 60+ project teams worldwide</li>
            <li class="flex gap-2"><span style="color:#10B981;">▸</span>Won the <span style="color:#E8EDF5;">2022 Academy Health Data Challenge</span> for advancing healthcare equity through analytics, geospatial visualizations, and machine learning</li>
            <li class="flex gap-2"><span style="color:#10B981;">▸</span>Authored multiple technical blogs including AI/ML for multilingual search</li>
          </ul>
        </div>

        <div class="glass-card p-6 border-l-2" style="border-left-color:#7A8BA8;">
          <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
            <div>
              <h3 class="font-bold text-lg" style="color:#E8EDF5;">Systems Engineer Staff / DevOps</h3>
              <p class="text-sm font-medium" style="color:#7A8BA8;">Lockheed Martin · Orlando, FL</p>
            </div>
            <span class="font-mono text-xs px-2 py-1 rounded" style="background:rgba(122,139,168,0.1); color:#7A8BA8;">Sep 2008 – Feb 2022</span>
          </div>
          <ul class="space-y-2 text-sm" style="color:#7A8BA8;">
            <li class="flex gap-2"><span style="color:#7A8BA8;">▸</span>Led systems architecture, automated testing, and DevOps across programs including Australian Defence Force Core Simulation, UK Military Flight Training System, SOF CLS, and F-35 JSF</li>
            <li class="flex gap-2"><span style="color:#7A8BA8;">▸</span>Developed microservices using Angular, Spring Boot, and Kafka; containerized with Docker; orchestrated deployments with Helm and Kubernetes</li>
            <li class="flex gap-2"><span style="color:#7A8BA8;">▸</span>Participated in the Advanced Technical Leadership Program; coordinated with program executive offices on system integration, RFPs, and milestone reviews (SRR, PDR, CDR)</li>
          </ul>
        </div>

        <div class="glass-card p-6 border-l-2" style="border-left-color:#7A8BA8;">
          <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
            <div>
              <h3 class="font-bold text-lg" style="color:#E8EDF5;">Avionics Systems Engineer</h3>
              <p class="text-sm font-medium" style="color:#7A8BA8;">Boeing · Everett, WA</p>
            </div>
            <span class="font-mono text-xs px-2 py-1 rounded" style="background:rgba(122,139,168,0.1); color:#7A8BA8;">Nov 2004 – Aug 2008</span>
          </div>
          <ul class="space-y-2 text-sm" style="color:#7A8BA8;">
            <li class="flex gap-2"><span style="color:#7A8BA8;">▸</span>Led requirements development, system design, and integration testing for airplane health management systems on the <span style="color:#E8EDF5;">Boeing 787 Dreamliner</span></li>
            <li class="flex gap-2"><span style="color:#7A8BA8;">▸</span>Provided oversight of Honeywell subcontractor team in Phoenix and India; led design reviews (SRR, PDR, CDR)</li>
            <li class="flex gap-2"><span style="color:#7A8BA8;">▸</span>Pre-sales engineering with clients including Japan Airlines and Air Nippon Airways</li>
          </ul>
        </div>

      </div>
    </div>

    <!-- Education -->
    <div class="mt-16 animate-fade-in-up">
      <div class="mb-8">
        <span class="font-mono text-sm" style="color:#D4A017;">$ cat education.md</span>
        <h2 class="text-2xl font-bold mt-3 mb-2" style="color:#E8EDF5;">Education</h2>
        <div class="h-1 w-16 rounded" style="background: linear-gradient(135deg, #D4A017, #F0C040);"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        {[
          {
            school: 'University of Illinois Urbana-Champaign',
            degree: 'M.S. Computer Science',
            period: '2012 – 2015',
            note: '4.0 GPA',
          },
          {
            school: 'University of Southern California',
            degree: 'M.S. Systems Architecture & Engineering',
            period: '2005 – 2009',
            note: '4.0 GPA · Aerospace & Mechanical Systems',
          },
          {
            school: 'Johns Hopkins University',
            degree: 'B.S. Electrical Engineering',
            period: '1999 – 2003',
            note: 'Minor: Mathematics · Minor: Entrepreneurship & Management',
          },
        ].map(edu => (
          <div class="glass-card p-5">
            <div class="font-mono text-xs mb-2" style="color:#D4A017;">{edu.period}</div>
            <div class="font-bold text-sm mb-1" style="color:#E8EDF5;">{edu.school}</div>
            <div class="text-sm mb-2" style="color:#10B981;">{edu.degree}</div>
            <div class="text-xs" style="color:#7A8BA8;">{edu.note}</div>
          </div>
        ))}
      </div>
    </div>

  </section>
</BaseLayout>
