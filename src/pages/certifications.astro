---
import BaseLayout from '../layouts/BaseLayout.astro';

const certGroups = [
  {
    domain: 'Kubernetes & DevOps',
    color: 'gold',
    certs: [
      { name: 'Certified Kubernetes Administrator (CKA)', issuer: 'CNCF', date: '', link: 'https://www.credly.com/badges/046af1c9-cb44-4bfa-aa84-0857afb83ffd/linked_in_profile', logo: 'https://images.credly.com/size/340x340/images/8b8ed108-e77d-4396-ac59-2504583b9d54/cka_from_cncfsite__281_29.png' },
      { name: 'Certified Kubernetes Application Developer (CKAD)', issuer: 'CNCF', date: '', link: 'https://www.credly.com/badges/3293a4de-533e-4729-b546-e77cfb0b6298/linked_in_profile', logo: 'https://images.credly.com/size/340x340/images/f88d800c-5261-45c6-9515-0458e31c3e16/ckad_from_cncfsite.png' },
      { name: 'Certified Scrum Product Owner (CSPO)', issuer: 'Scrum Alliance', date: '', link: 'https://www.credly.com/badges/bb71a107-4dc1-4126-87a1-69bc6b95eab9/public_url' },
    ],
  },
  {
    domain: 'Cloud',
    color: 'emerald',
    certs: [
      { name: 'AWS Solutions Architect – Associate', issuer: 'Amazon Web Services', date: '', link: 'https://www.credly.com/badges/9ebaf4c1-3ec1-43c9-8af2-4260ecb6efb1?source=linked_in_profile', logo: 'https://images.credly.com/size/340x340/images/0e284c3f-5164-4b21-8660-0d84737941bc/image.png' },
      { name: 'AWS Cloud Practitioner', issuer: 'Amazon Web Services', date: '', link: 'https://www.credly.com/badges/02bb6edc-13aa-4fee-a461-4ef9ac6f33ba/linked_in_profile', logo: 'https://images.credly.com/size/340x340/images/00634f82-b07f-4bbd-a6bb-53de397fc3a6/image.png' },
      { name: 'Azure Fundamentals (AZ-900)', issuer: 'Microsoft', date: '', link: 'https://www.credly.com/badges/0bd46560-b4bf-47a0-a27d-99c8ee96823d?source=linked_in_profile', logo: 'https://images.credly.com/size/340x340/images/be8fcaeb-c769-4858-b567-ffaaa73ce8cf/image.png' },
    ],
  },
  {
    domain: 'Security & Observability',
    color: 'coral',
    certs: [
      { name: 'Security+', issuer: 'CompTIA', date: '', link: 'https://www.credly.com/badges/55b1a9a7-b9b8-4151-9cfb-eedee6e5591e/public_url', logo: 'https://cin.comptia.org/media/securityplus-logo-certified-ce-png.8/full' },
      { name: 'Elastic Certified Engineer', issuer: 'Elastic', date: '', link: 'https://certified.elastic.co/0b1ab049-db50-4bdd-85d6-e675e733bf3a#acc.uVwWrtIs', logo: 'https://images.credly.com/size/340x340/images/b1b8e4b8-4ea0-4f1e-917f-cb3a7d1e2c06/image.png' },
      { name: 'Elastic Certified Observability Engineer', issuer: 'Elastic', date: '', link: 'https://certified.elastic.co/7a109676-c06d-45de-b756-4325d104d19f#acc.XIsflrR9' },
    ],
  },
];
---

<BaseLayout title="Certifications — Isra Sunhachawi">
  <section class="max-w-6xl mx-auto px-6 py-20">

    <div class="mb-12 animate-fade-in-up">
      <span class="font-mono text-sm" style="color:#D4A017;">$ ls certifications/</span>
      <h1 class="text-4xl font-bold mt-3 mb-2" style="color:#E8EDF5;">Certifications</h1>
      <div class="h-1 w-16 rounded" style="background: linear-gradient(135deg, #D4A017, #F0C040);"></div>
      <p class="mt-4 text-sm" style="color:#7A8BA8;">Third-party verified credentials. Click any badge to verify.</p>
    </div>

    <div class="space-y-10">
      {certGroups.map((group, i) => (
        <div class="animate-fade-in-up" style={`animation-delay:${i * 0.1}s; opacity:0;`}>
          <h2 class="font-bold mb-4" style={`color:${group.color === 'gold' ? '#D4A017' : group.color === 'emerald' ? '#10B981' : '#F08080'};`}>
            {group.domain}
          </h2>
          <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
            {group.certs.map(cert => {
              const accentRgb = group.color === 'gold' ? '212,160,23' : group.color === 'emerald' ? '0,145,110' : '224,92,92';
              const accentHex = group.color === 'gold' ? '#D4A017' : group.color === 'emerald' ? '#10B981' : '#F08080';
              const cardContent = (
                <>
                  <div class="w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0 overflow-hidden" style={`background:rgba(${accentRgb},0.1);`}>
                    {cert.logo ? (
                      <img src={cert.logo} alt={cert.name} width="48" height="48" class="w-full h-full object-contain p-1" />
                    ) : (
                      <svg width="20" height="20" fill="none" stroke={accentHex} stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                      </svg>
                    )}
                  </div>
                  <div>
                    <div class="font-medium text-sm" style="color:#E8EDF5;">{cert.name}</div>
                    {cert.issuer && <div class="text-xs mt-1" style="color:#7A8BA8;">{cert.issuer} · {cert.date}</div>}
                  </div>
                </>
              );
              return cert.link ? (
                <a href={cert.link} target="_blank" rel="noopener noreferrer" class="glass-card p-5 flex items-center gap-4 hover:opacity-80 transition-opacity">
                  {cardContent}
                </a>
              ) : (
                <div class="glass-card p-5 flex items-center gap-4">
                  {cardContent}
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>


  </section>
</BaseLayout>
