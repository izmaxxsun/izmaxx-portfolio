---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = [
  {
    slug: 'air-gapped-llm-architecture',
    title: 'Building an Air-Gapped LLM on k0s: Architecture Decisions',
    date: '2026-04-01',
    readTime: '8 min read',
    tags: ['Ollama', 'k0s', 'Air-Gap', 'DevSecOps'],
    excerpt: 'Why every LLM call to a third-party API is a trust decision — and how to build private AI infrastructure that provably never leaves your perimeter.',
    status: 'Coming soon',
  },
  {
    slug: 'tribal-knowledge-ai-guardrails',
    title: 'Same Guardrail, Five Platforms: Codifying Enterprise Knowledge',
    date: '2026-04-15',
    readTime: '10 min read',
    tags: ['Claude Code', 'LangGraph', 'n8n', 'Enterprise AI'],
    excerpt: 'How we encoded 5 years of unwritten team rules into AI guardrails — and why the concept matters more than the platform.',
    status: 'Coming soon',
  },
];
---

<BaseLayout title="Blog — Isra Sunhachawi">
  <section class="max-w-4xl mx-auto px-6 py-20">

    <div class="mb-12 animate-fade-in-up">
      <span class="font-mono text-sm" style="color:#D4A017;">$ ls blog/</span>
      <h1 class="text-4xl font-bold mt-3 mb-2" style="color:#E8EDF5;">Blog</h1>
      <div class="h-1 w-16 rounded" style="background: linear-gradient(135deg, #D4A017, #F0C040);"></div>
      <p class="mt-4 text-sm" style="color:#7A8BA8;">Technical writing on DevSecOps, private AI, and enterprise engineering.</p>
    </div>

    <div class="space-y-6">
      {posts.map((post, i) => (
        <div
          class="glass-card p-6 animate-fade-in-up"
          style={`animation-delay:${i * 0.1}s; opacity:0;`}
        >
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs" style="color:#7A8BA8;">{post.date}</span>
              <span class="font-mono text-xs" style="color:#7A8BA8;">·</span>
              <span class="font-mono text-xs" style="color:#7A8BA8;">{post.readTime}</span>
            </div>
            <span class="font-mono text-xs px-2 py-1 rounded" style="background:rgba(212,160,23,0.1); color:#D4A017;">{post.status}</span>
          </div>
          <h2 class="text-xl font-bold mb-2" style="color:#E8EDF5;">{post.title}</h2>
          <p class="text-sm mb-4" style="color:#7A8BA8;">{post.excerpt}</p>
          <div class="flex flex-wrap gap-2">
            {post.tags.map(tag => (
              <span class="skill-tag">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

  </section>
</BaseLayout>
