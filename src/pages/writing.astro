---
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = [
  {
    title: 'Harnessing Search to Advance Equity in Healthcare',
    publisher: 'Elastic Blog',
    description: 'How search technology can be applied to surface disparities and drive more equitable outcomes in healthcare systems.',
    url: 'https://www.elastic.co/blog/harnessing-search-to-advance-equity-in-healthcare',
    tags: ['Elasticsearch', 'Healthcare', 'Search'],
    color: 'coral',
  },
];
---

<BaseLayout title="Writing — Isra Sunhachawi">
  <section class="max-w-6xl mx-auto px-6 py-20">

    <div class="mb-12 animate-fade-in-up">
      <span class="font-mono text-sm" style="color:#D4A017;">$ cat writing/</span>
      <h1 class="text-4xl font-bold mt-3 mb-2" style="color:#E8EDF5;">Writing</h1>
      <div class="h-1 w-16 rounded" style="background: linear-gradient(135deg, #D4A017, #F0C040);"></div>
      <p class="mt-4 text-sm" style="color:#7A8BA8;">Published articles and technical writing on AI, DevSecOps, and engineering.</p>
    </div>

    <div class="space-y-6">
      {posts.map((post, i) => {
        const accentHex = post.color === 'gold' ? '#D4A017' : post.color === 'emerald' ? '#10B981' : '#F08080';
        const accentRgb = post.color === 'gold' ? '212,160,23' : post.color === 'emerald' ? '0,145,110' : '240,128,128';
        return (
          <a
            href={post.url}
            target="_blank"
            rel="noopener noreferrer"
            class="glass-card p-6 flex flex-col sm:flex-row sm:items-start gap-5 hover:opacity-80 transition-opacity animate-fade-in-up group"
            style={`animation-delay:${i * 0.1}s; opacity:0;`}
          >
            <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style={`background:rgba(${accentRgb},0.1);`}>
              <svg width="18" height="18" fill="none" stroke={accentHex} stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-3 mb-1">
                <h2 class="text-base font-semibold leading-snug" style="color:#E8EDF5;">{post.title}</h2>
                <svg width="14" height="14" fill="none" stroke="#7A8BA8" stroke-width="2" viewBox="0 0 24 24" class="flex-shrink-0 mt-1 transition-colors group-hover:stroke-[#D4A017]">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </div>
              <div class="text-xs mb-2" style={`color:${accentHex};`}>{post.publisher}</div>
              <p class="text-sm mb-3" style="color:#7A8BA8;">{post.description}</p>
              <div class="flex flex-wrap gap-2">
                {post.tags.map(tag => (
                  <span class="font-mono text-xs px-2 py-0.5 rounded" style={`background:rgba(${accentRgb},0.1); color:${accentHex};`}>{tag}</span>
                ))}
              </div>
            </div>
          </a>
        );
      })}
    </div>

  </section>
</BaseLayout>
