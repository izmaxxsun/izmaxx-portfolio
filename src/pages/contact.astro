---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Isra Sunhachawi">
  <section class="max-w-4xl mx-auto px-6 py-20">

    <div class="mb-12 animate-fade-in-up">
      <span class="font-mono text-sm" style="color:#D4A017;">$ ping izmaxx</span>
      <h1 class="text-4xl font-bold mt-3 mb-2" style="color:#E8EDF5;">Get in Touch</h1>
      <div class="h-1 w-16 rounded" style="background: linear-gradient(135deg, #D4A017, #F0C040);"></div>
      <p class="mt-4 text-sm" style="color:#7A8BA8;">Open to conversations about DevSecOps, AI security, and engineering leadership roles.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-10">

      <!-- Form -->
      <div class="animate-fade-in-up animate-delay-100">
        <form
          action="https://formspree.io/f/xykbzayd"
          method="POST"
          class="space-y-5"
        >
          <div>
            <label class="block font-mono text-xs mb-2" style="color:#7A8BA8;">NAME</label>
            <input
              type="text"
              name="name"
              required
              class="w-full px-4 py-3 rounded-lg text-sm transition-all outline-none"
              style="background:#131C31; border:1px solid #1E2D4A; color:#E8EDF5;"
              onfocus="this.style.borderColor='rgba(212,160,23,0.5)'"
              onblur="this.style.borderColor='#1E2D4A'"
              placeholder="Your name"
            />
          </div>
          <div>
            <label class="block font-mono text-xs mb-2" style="color:#7A8BA8;">EMAIL</label>
            <input
              type="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-lg text-sm transition-all outline-none"
              style="background:#131C31; border:1px solid #1E2D4A; color:#E8EDF5;"
              onfocus="this.style.borderColor='rgba(212,160,23,0.5)'"
              onblur="this.style.borderColor='#1E2D4A'"
              placeholder="you@example.com"
            />
          </div>
          <div>
            <label class="block font-mono text-xs mb-2" style="color:#7A8BA8;">MESSAGE</label>
            <textarea
              name="message"
              required
              rows="5"
              class="w-full px-4 py-3 rounded-lg text-sm transition-all outline-none resize-none"
              style="background:#131C31; border:1px solid #1E2D4A; color:#E8EDF5;"
              onfocus="this.style.borderColor='rgba(212,160,23,0.5)'"
              onblur="this.style.borderColor='#1E2D4A'"
              placeholder="What's on your mind?"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full py-3 rounded-lg font-semibold text-sm transition-all duration-200"
            style="background: linear-gradient(135deg, #D4A017, #F0C040); color: #0B1120;"
            onmouseover="this.style.opacity='0.9'"
            onmouseout="this.style.opacity='1'"
          >
            Send Message
          </button>
        </form>
      </div>

      <!-- Links -->
      <div class="space-y-5 animate-fade-in-up animate-delay-200">
        <div class="glass-card p-5">
          <div class="font-mono text-xs mb-4" style="color:#D4A017;">ELSEWHERE</div>
          <div class="space-y-4">
            {[
              {
                label: 'GitHub',
                value: '@izmaxxsun',
                href: 'https://github.com/izmaxxsun',
                icon: '<path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>',
              },
              {
                label: 'LinkedIn',
                value: 'Isra Sunhachawi',
                href: 'https://www.linkedin.com/in/isunhachawi',
                icon: '<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>',
              },
            ].map(link => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener"
                class="flex items-center gap-3 transition-colors group"
                style="color:#7A8BA8; text-decoration:none;"
                onmouseover="this.style.color='#D4A017'"
                onmouseout="this.style.color='#7A8BA8'"
              >
                <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" set:html={link.icon} />
                <div>
                  <div class="text-xs font-mono" style="color:inherit; opacity:0.6;">{link.label}</div>
                  <div class="text-sm font-medium" style="color:#E8EDF5;">{link.value}</div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <div class="glass-card p-5">
          <div class="font-mono text-xs mb-2" style="color:#D4A017;">RESPONSE TIME</div>
          <p class="text-sm" style="color:#7A8BA8;">Usually within 24-48 hours. For urgent opportunities, LinkedIn DMs get a faster response.</p>
        </div>
      </div>
    </div>

  </section>
</BaseLayout>
