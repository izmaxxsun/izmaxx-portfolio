---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Isra Sunhachawi — DevSecOps & AI Practitioner">

  <!-- Hero -->
  <section class="min-h-screen flex items-center justify-center px-6 relative overflow-hidden">

    <!-- Background glow orbs -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(212,160,23,0.06) 0%, transparent 70%);"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(0,145,110,0.06) 0%, transparent 70%);"></div>

    <div class="max-w-4xl mx-auto text-center relative z-10">

      <!-- Terminal window -->
      <div class="glass-card glow-gold mb-10 text-left max-w-xl mx-auto animate-fade-in-up">
        <div class="flex items-center gap-2 px-4 py-3" style="border-bottom: 1px solid #1E2D4A;">
          <div class="w-3 h-3 rounded-full" style="background:#E05C5C;"></div>
          <div class="w-3 h-3 rounded-full" style="background:#D4A017;"></div>
          <div class="w-3 h-3 rounded-full" style="background:#00916E;"></div>
          <span class="ml-2 font-mono text-xs" style="color:#7A8BA8;">izmaxx — zsh</span>
        </div>
        <div class="px-4 py-4 font-mono text-sm" style="color:#E8EDF5;">
          <div style="color:#7A8BA8;">$ whoami</div>
          <div class="mt-1" style="color:#D4A017;">isra_sunhachawi</div>
          <div class="mt-3" style="color:#7A8BA8;">$ cat mission.txt</div>
          <div id="typewriter" class="mt-1" style="color:#10B981; min-height: 1.5em;"></div>
          <span class="cursor-blink" style="color:#D4A017;">▊</span>
        </div>
      </div>

      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4 animate-fade-in-up animate-delay-100">
        <span style="color:#E8EDF5;">Isra </span><span class="gold-text">Sunhachawi</span>
      </h1>

      <p class="text-lg md:text-xl font-medium mb-4 animate-fade-in-up animate-delay-200" style="color:#7A8BA8;">
        Engineering Leader &nbsp;·&nbsp; DevSecOps &nbsp;·&nbsp; AI Practitioner
      </p>

      <p class="text-base max-w-2xl mx-auto mb-10 animate-fade-in-up animate-delay-300" style="color:#7A8BA8; line-height:1.8;">
        20 years spanning systems engineering, software engineering, DevOps, and pre-sales — now focused on
        <span style="color:#D4A017;">AI-enabled developer experience</span> and modern DevSecOps at the intersection of platform engineering and applied AI.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4 animate-fade-in-up animate-delay-400">
        <a href={`${base}/projects`} class="px-6 py-3 rounded-lg font-semibold text-sm transition-all duration-200" style="background: linear-gradient(135deg, #D4A017, #F0C040); color: #0B1120;">
          View Projects
        </a>
        <a href={`${base}/contact`} class="px-6 py-3 rounded-lg font-semibold text-sm transition-all duration-200" style="color:#7A8BA8;" onmouseover="this.style.color='#E8EDF5'" onmouseout="this.style.color='#7A8BA8'">
          Get in Touch →
        </a>
      </div>

      <!-- Quick links -->
      <div class="flex items-center justify-center gap-6 mt-10 animate-fade-in-up animate-delay-400">
        <a href="https://github.com/izmaxxsun" target="_blank" rel="noopener" class="flex items-center gap-2 text-sm transition-colors" style="color:#7A8BA8;" onmouseover="this.style.color='#D4A017'" onmouseout="this.style.color='#7A8BA8'">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
          GitHub
        </a>
        <a href="https://www.linkedin.com/in/isunhachawi" target="_blank" rel="noopener" class="flex items-center gap-2 text-sm transition-colors" style="color:#7A8BA8;" onmouseover="this.style.color='#D4A017'" onmouseout="this.style.color='#7A8BA8'">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
    </div>
  </section>

  <!-- Featured projects preview -->
  <section class="max-w-6xl mx-auto px-6 pb-24">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold" style="color:#E8EDF5;">Featured Projects</h2>
      <a href={`${base}/projects`} class="text-sm font-medium transition-colors" style="color:#D4A017;" onmouseover="this.style.color='#F0C040'" onmouseout="this.style.color='#D4A017'">View all →</a>
    </div>

    <div class="grid md:grid-cols-2 gap-6">

      <div class="glass-card p-6 transition-all duration-300 glow-gold group" style="cursor:pointer;" onclick={`window.location='${base}/projects/gitlab-analyzer'`}>
        <div class="flex items-start justify-between mb-3">
          <span class="font-mono text-xs px-2 py-1 rounded" style="background:rgba(212,160,23,0.1); color:#D4A017;">Project 02</span>
          <svg width="16" height="16" fill="none" stroke="#7A8BA8" stroke-width="2" viewBox="0 0 24 24" class="transition-colors group-hover:stroke-[#D4A017]"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </div>
        <h3 class="text-lg font-bold mb-2" style="color:#E8EDF5;">GitLab Project Analyzer</h3>
        <p class="text-sm mb-4" style="color:#7A8BA8;">Go CLI that inventories GitLab projects org-wide — detecting languages, tools, and CI/CD pipeline health to surface inconsistencies before they become incidents.</p>
        <div class="flex flex-wrap gap-2">
          <span class="skill-tag">Go</span>
          <span class="skill-tag">GitLab API</span>
          <span class="skill-tag">CI/CD</span>
          <span class="skill-tag">Pipeline Analytics</span>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<script is:inline>
  const lines = [
    'Securing systems. Automating trust.',
    'AI-enabled developer experience.',
    'Tribal knowledge → AI guardrails.',
    '20 years. Still shipping.',
  ];
  let lineIndex = 0;
  let charIndex = 0;
  let deleting = false;
  const el = document.getElementById('typewriter');

  function type() {
    if (!el) return;
    const current = lines[lineIndex];
    if (!deleting) {
      el.textContent = current.slice(0, charIndex + 1);
      charIndex++;
      if (charIndex === current.length) {
        deleting = true;
        setTimeout(type, 2000);
        return;
      }
    } else {
      el.textContent = current.slice(0, charIndex - 1);
      charIndex--;
      if (charIndex === 0) {
        deleting = false;
        lineIndex = (lineIndex + 1) % lines.length;
      }
    }
    setTimeout(type, deleting ? 40 : 70);
  }

  type();
</script>
